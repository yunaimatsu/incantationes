# alias of alias
a() {
  alias "$1"="$2"
}

# exec `^.e$`
alias be='bundle exec'
alias de='docker exec'

# log `^.l$`
alias gl='git log'
alias dl='docker logs'

# config `^.c$`
alias gc='git config'
alias bc='bundle config'
alias nc='npm config'
alias pc='pip config'

# ps `^.p$`
alias dp='docker ps'

# Text manipulation
